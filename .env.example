# Base de datos
DATABASE_URL=postgresql://almacen:almacen_dev@localhost:5432/almacen_db

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_seguro_minimo_32_chars
JWT_REFRESH_SECRET=otro_secreto_diferente_minimo_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Email (Nodemailer — compatible con Gmail, Outlook, cualquier SMTP)
# Para Gmail: activá 2FA → generá una "Contraseña de aplicación" en myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=contraseña-de-aplicacion-de-google
SMTP_FROM=VENTRA ARG <tu-email@gmail.com>

# Mercado Pago (FASE 6)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
