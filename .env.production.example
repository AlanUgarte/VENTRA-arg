# ─────────────────────────────────────────────────────────────────────────────
# PRODUCCIÓN — copiar como .env en el servidor y completar todos los valores
# ─────────────────────────────────────────────────────────────────────────────

# Base de datos
DB_USER=almacen
DB_PASSWORD=CAMBIA_ESTO_POR_CONTRASEÑA_SEGURA
DB_NAME=almacen_db
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}

# JWT — generar con: openssl rand -hex 32
JWT_SECRET=GENERA_UN_SECRETO_DE_64_CHARS_MINIMO_AQUI_OPENSSL_RAND_HEX_32
JWT_REFRESH_SECRET=OTRO_SECRETO_DIFERENTE_DE_64_CHARS_OPENSSL_RAND_HEX_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=4000
NODE_ENV=production
APP_URL=https://tudominio.com
CORS_ORIGIN=https://tudominio.com

# Mercado Pago (FASE 6)
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=WEBHOOK_SECRET_DE_MP

# Frontend
NEXT_PUBLIC_API_URL=https://tudominio.com/api
