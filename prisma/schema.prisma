generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// TENANT
// ─────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  subscription   Subscription?
  rubros         Rubro[]
  products       Product[]
  sales          Sale[]
  customers      Customer[]
  suppliers      Supplier[]
  paymentMethods  PaymentMethod[]
  auditLogs       AuditLog[]
  supplierReturns SupplierReturn[]
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  CASHIER
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String
  password     String
  role         Role     @default(CASHIER)
  isActive     Boolean  @default(true)
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  sales         Sale[]
  auditLogs     AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([isSuperAdmin])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────
// SUSCRIPCIONES
// ─────────────────────────────────────────────

enum Plan {
  TRIAL
  BASIC
  PRO
  ENTERPRISE
}

enum SubStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

model Subscription {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  plan             Plan      @default(TRIAL)
  status           SubStatus @default(TRIAL)
  trialEndsAt      DateTime
  currentPeriodEnd DateTime?
  mpSubscriptionId String?
  mpPayerId        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// CATÁLOGO
// ─────────────────────────────────────────────

model Rubro {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#0d9f6e")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Product {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rubroId    String
  rubro      Rubro    @relation(fields: [rubroId], references: [id])
  name       String
  barcode    String?  // Código de barras EAN-13 / EAN-8 / Code128
  costoBase  Decimal  @db.Decimal(12, 2)
  descCompra Decimal  @default(0)  @db.Decimal(5, 2)
  ganancia   Decimal  @default(40) @db.Decimal(5, 2)
  stock      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  saleLines       SaleLine[]
  creditLines     CreditLine[]
  supplierReturns SupplierReturn[]

  @@index([tenantId])
  @@index([tenantId, rubroId])
  @@index([tenantId, isActive])
  @@index([tenantId, barcode])
}

// ─────────────────────────────────────────────
// VENTAS (precio fijado al momento de la venta)
// ─────────────────────────────────────────────

enum SaleType {
  CASH
  CREDIT
}

model Sale {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  orderNumber    Int
  type           SaleType  @default(CASH)
  discountPct    Decimal   @default(0) @db.Decimal(5, 2)
  subtotal       Decimal   @db.Decimal(12, 2)
  discountAmount Decimal   @default(0) @db.Decimal(12, 2)
  total          Decimal   @db.Decimal(12, 2)
  createdAt      DateTime  @default(now())

  lines  SaleLine[]
  credit Credit?

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, customerId])
  @@index([tenantId, type])
}

model SaleLine {
  id          String   @id @default(cuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  productName String
  rubroName   String
  priceUnit   Decimal  @db.Decimal(12, 2)
  costUnit    Decimal  @db.Decimal(12, 2)
  quantity    Int
  subtotal    Decimal  @db.Decimal(12, 2)

  @@index([saleId])
}

// ─────────────────────────────────────────────
// CLIENTES Y FIADOS (precio revaluado al día)
// ─────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales    Sale[]
  credits  Credit[]
  payments CustomerPayment[]

  @@index([tenantId])
  @@index([tenantId, name])
}

model Credit {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  saleId      String?  @unique
  sale        Sale?    @relation(fields: [saleId], references: [id])
  discountPct Decimal  @default(0) @db.Decimal(5, 2)
  createdAt   DateTime @default(now())

  lines CreditLine[]

  @@index([tenantId])
  @@index([customerId])
}

model CreditLine {
  id          String   @id @default(cuid())
  creditId    String
  credit      Credit   @relation(fields: [creditId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  productName String
  priceSnap   Decimal  @db.Decimal(12, 2)
  quantity    Int

  @@index([creditId])
}

model CustomerPayment {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  amount     Decimal  @db.Decimal(12, 2)
  method     String
  reference  String?
  paidAt     DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([customerId])
}

// ─────────────────────────────────────────────
// PROVEEDORES
// ─────────────────────────────────────────────

enum PaymentCondition {
  CASH
  DAYS_15
  DAYS_30
  DAYS_60
  DAYS_90
  CURRENT_ACCOUNT
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  invoices SupplierInvoice[]
  returns  SupplierReturn[]

  @@index([tenantId])
}

model SupplierInvoice {
  id            String           @id @default(cuid())
  tenantId      String
  supplierId    String
  supplier      Supplier         @relation(fields: [supplierId], references: [id])
  invoiceNumber String
  condition     PaymentCondition @default(CASH)
  issuedAt      DateTime
  dueAt         DateTime?
  amount        Decimal          @db.Decimal(12, 2)
  status        InvoiceStatus    @default(PENDING)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  payments SupplierPayment[]

  @@index([tenantId])
  @@index([supplierId])
  @@index([tenantId, status])
  @@index([tenantId, dueAt])
}

model SupplierPayment {
  id        String          @id @default(cuid())
  tenantId  String
  invoiceId String
  invoice   SupplierInvoice @relation(fields: [invoiceId], references: [id])
  amount    Decimal         @db.Decimal(12, 2)
  method    String
  reference String?
  paidAt    DateTime        @default(now())
  createdAt DateTime        @default(now())

  @@index([tenantId])
  @@index([invoiceId])
}

// ─────────────────────────────────────────────
// DEVOLUCIONES A PROVEEDORES
// ─────────────────────────────────────────────

enum ReturnStatus {
  PENDING    // Devuelto, esperando crédito/reposición
  CREDITED   // Proveedor acreditó el monto
  REPLACED   // Proveedor repuso el artículo
  REJECTED   // Proveedor rechazó la devolución
}

enum ReturnReason {
  BROKEN      // Rotura
  EXPIRED     // Vencimiento
  DEFECTIVE   // Defecto de fábrica
  WRONG_ITEM  // Artículo incorrecto
  OTHER       // Otro motivo
}

model SupplierReturn {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier      @relation(fields: [supplierId], references: [id])
  productId    String?
  product      Product?      @relation(fields: [productId], references: [id])
  productName  String        // snapshot del nombre
  quantity     Int
  reason       ReturnReason
  reasonDetail String?       // descripción adicional
  status       ReturnStatus  @default(PENDING)
  creditAmount Decimal?      @db.Decimal(12, 2) // monto acreditado (si aplica)
  returnedAt   DateTime      @default(now())
  resolvedAt   DateTime?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tenantId])
  @@index([tenantId, supplierId])
  @@index([tenantId, status])
}

// ─────────────────────────────────────────────
// MEDIOS DE PAGO
// ─────────────────────────────────────────────

model PaymentMethod {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)
  order     Int     @default(0)

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

model AuditLog {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  entity    String
  entityId  String
  action    AuditAction
  before    Json?
  after     Json?
  createdAt DateTime    @default(now())

  @@index([tenantId])
  @@index([tenantId, entity])
  @@index([tenantId, createdAt])
}
